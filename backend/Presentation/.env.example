# Database
DEFAULTCONNECTION=Host=localhost;Port=5432;Database=cirkit;Username=postgres;Password=yourpassword

# JWT
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long-for-hmacsha256
JWT_ISSUER=CirKit
JWT_AUDIENCE=CirKitUsers
JWT_LIFETIME_MINUTES=1440

# Stripe (prepared for future integration — not active yet)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS
CORS_ORIGIN=http://localhost:5173
